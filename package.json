{
  "name": "andres-english-tutor",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based English tutor with Gemini, Supabase Edge Functions, speech input, speech synthesis, guided lessons, quizzes and AI usage controls.",
  "homepage": "https://andresito202.github.io/andres-english-tutor/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Andresito202/andres-english-tutor.git"
  },
  "keywords": [
    "english-learning",
    "ai-tutor",
    "gemini",
    "supabase-edge-functions",
    "web-speech-api",
    "react",
    "vite",
    "github-pages"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "check": "npm run lint && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "@google/genai": "latest",
    "react": "^18.2.0",
